{
  "name": "signforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@signforge/web",
    "build": "npm run build --workspace=@signforge/web",
    "lint": "npm run lint --workspace=@signforge/web",
    "typecheck": "npm run typecheck --workspace=@signforge/web",
    "test": "npm run test --workspace=@signforge/web",
    "format": "prettier --write ."
  },
  "dependencies": {
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "prettier": "latest",
    "typescript": "latest"
  }
}